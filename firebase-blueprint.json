{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Customer information and saved addresses",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "addresses": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "orderNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderNumber", "customerName", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile" },
    "/orders/{orderId}": { "schema": "Order" }
  }
}
